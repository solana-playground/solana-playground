# Runtime config for the Rust server. Read by server/src/config.rs (PG_* only).
PG_PORT=8080
PG_PAYLOAD_LIMIT=1048576
PG_VERBOSE=false
# CORS — allowed frontend origin (production: https://beta.solpg.io)
PG_CLIENT_URL=http://localhost:3000
# MongoDB
PG_DB_URI=mongodb://localhost:27017
PG_DB_NAME=solpg
# API-key gate. Empty = disabled.
# PG_API_KEY: single key. PG_API_KEYS: list (current + previous, for rotation).
PG_API_KEY=
PG_API_KEYS=
